{
  "name": "ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "node scripts/prepare-stockfish.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "prepare": "cd .. && husky .husky",
    "test": "node --test",
    "migrate:tailwind:audit-css": "node scripts/tailwind-migration/audit-css-module.mjs",
    "migrate:tailwind:audit-jsx": "node scripts/tailwind-migration/audit-jsx-usage.mjs",
    "migrate:tailwind:apply-inline": "node scripts/tailwind-migration/apply-inline.mjs",
    "migrate:tailwind:apply-all": "node scripts/tailwind-migration/apply-inline.mjs --write",
    "migrate:tailwind:audit": "node scripts/tailwind-migration/audit-css-module.mjs && node scripts/tailwind-migration/audit-jsx-usage.mjs && node scripts/tailwind-migration/dry-run-convert.mjs",
    "chesscom:recent": "node scripts/chesscom/fetch-recent-games.mjs",
    "chesscom:audit:analysis": "node scripts/chesscom/audit-analysis.mjs",
    "chesscom:build:deck": "node scripts/chesscom/build-recent-blitz-deck.mjs",
    "chesscom:build:opening-trees": "node scripts/chesscom/build-opening-trees.mjs",
    "opening:purge": "node scripts/purge-opening-data.mjs",
    "opening:smoke-rebuild": "node scripts/smoke/opening-graph-rebuild.mjs",
    "opening:full-rebuild": "node scripts/purge-opening-data.mjs && node scripts/chesscom/build-opening-trees.mjs",
    "supabase:migrate": "node scripts/supabase/migrate.mjs",
    "supabase:apply-migration": "node scripts/supabase/apply-migration.mjs",
    "supabase:seed": "node scripts/supabase/seed-decks.mjs",
    "supabase:seed:cards": "node scripts/supabase/seed-punish-cards.mjs",
    "supabase:purge:analysis-cache": "node scripts/supabase/purge-analysis-cache.mjs",
    "supabase:backfill:card-reviews": "node scripts/supabase/backfill-card-move-reviews.mjs",
    "supabase:backupdate:analysis": "node scripts/supabase/backupdate-analysis.mjs",
    "supabase:smoke": "node scripts/supabase/smoke.mjs",
    "supabase:audit:opening": "node scripts/supabase/audit-opening-graph.mjs",
    "supabase:fix:opening": "node scripts/supabase/fix-opening-graph.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@types/dagre": "^0.7.54",
    "@vercel/analytics": "^2.0.1",
    "@xyflow/react": "^12.11.0",
    "chart.js": "^4.5.1",
    "chess.js": "^1.4.0",
    "dagre": "^0.8.5",
    "next": "^16.2.6",
    "pg": "^8.21.0",
    "postcss": "^8.5.10",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-chessboard": "^5.10.0",
    "react-dom": "19.2.4",
    "stockfish": "^18.0.7",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,json,css}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "server-only": "^0.0.1",
    "tailwindcss": "^4",
    "transform-to-tailwindcss-core": "^0.0.43",
    "typescript": "^5"
  }
}
